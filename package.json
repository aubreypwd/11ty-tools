{
  "name": "@aubreypwd/11ty-starter",
  "version": "0.0.0",
  "description": "My starter setup for 11ty websites.",
  "keywords": [
    "11ty",
    "eleventy",
    "jamstack",
    "starter"
  ],
  "homepage": "https://github.com/aubreypwd/11ty-starter",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aubreypwd/11ty-starter.git"
  },
  "license": "UNLICENSED",
  "author": "Aubrey Portwood",
  "type": "commonjs",
  "main": "index.js",
  "_moduleAliases": {
    "@root": "."
  },
  "scripts": {
    "serve": "npm run reset && eleventy --serve",
    "build": "npm run reset && eleventy",
    "reset": "rimraf docs/",
    "tools:push": "git subtree push --prefix=src/_includes/11ty-starter-common git@github.com:aubreypwd/11ty-starter-common.git v2",
    "tools:pull": "git subtree pull --prefix=src/_includes/11ty-starter-common git@github.com:aubreypwd/11ty-starter-common.git v2 --squash",
    "tools:add": "git subtree add --prefix=src/_includes/11ty-starter-common git@github.com:aubreypwd/11ty-starter-common.git v2 --squash",
    "tools:readd": "git diff --quiet -- src/_includes/11ty-starter-common && git diff --cached --quiet -- src/_includes/11ty-starter-common && git rm -r --ignore-unmatch src/_includes/11ty-starter-common && git commit -m \"Remove copied 11ty-starter-common before subtree re-add\" && npm run tools:add",
    "tools:check": "git rev-parse --is-inside-work-tree >/dev/null 2>&1 || exit 0; git log --grep='^git-subtree-dir: src/_includes/11ty-starter-common$' --format=%H -n 1 --all | grep -q . && exit 0; [ -d \"src/_includes/11ty-starter-common\" ] && npm run tools:readd || npm run tools:add",
    "setup": "npm run setup:git-hooks",
    "setup:git-hooks": "git rev-parse --is-inside-work-tree >/dev/null 2>&1 && git config core.hooksPath .githooks || true",
    "postinstall": "npm run setup && npm run tools:check",
    "netlify:live": "netlify dev --live localhost",
    "netlify:dev": "netlify dev"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-img": "^6.0.4",
    "@aubreypwd/11ty-starter-common": "git+ssh://git@github.com:aubreypwd/11ty-starter-common.git",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@popperjs/core": "^2.11.8",
    "@quasibit/eleventy-plugin-sitemap": "^2.2.0",
    "@sardine/eleventy-plugin-tinycss": "^2.0.0",
    "@sardine/eleventy-plugin-tinyhtml": "^0.2.0",
    "bootstrap": "^5.3.8",
    "deepmerge": "^4.3.1",
    "eleventy-google-fonts": "^0.1.0",
    "eleventy-plugin-automatic-noopener": "^2.0.2",
    "eleventy-plugin-metagen": "^1.8.3",
    "eleventy-plugin-robotstxt": "^1.0.2",
    "eleventy-sass": "^3.0.0-beta.0",
    "esbuild": "^0.27.3",
    "humanize-list": "^1.0.1",
    "libphonenumber-js": "^1.12.41",
    "markdown-it": "^14.1.1",
    "module-alias": "^2.3.4",
    "node-html-parser": "^7.1.0",
    "purgecss-from-html": "^8.0.0",
    "qrcode": "^1.5.4",
    "rimraf": "^6.1.3",
    "sanitize.css": "^13.0.0",
    "schemaorg-jsd": "^0.17.1",
    "structured-data-testing-tool": "^4.5.0",
    "terser": "^5.46.0",
    "tippy.js": "^6.3.7"
  }
}
