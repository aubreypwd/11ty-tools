{
  "name": "@aubreypwd/11ty-505spotlight.com",
  "version": "0.0.0",
  "description": "505spotlight.com",
  "keywords": [],
  "homepage": "https://github.com/aubreypwd/11ty-starter",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aubreypwd/11ty-505spotlight.com.git"
  },
  "license": "UNLICENSED",
  "author": "Aubrey Portwood",
  "type": "commonjs",
  "main": "index.js",
  "_moduleAliases": {
    "@root": "."
  },
  "scripts": {
    "serve": "npm run reset && eleventy --serve",
    "build": "npm run reset && eleventy",
    "reset": "rimraf docs/",
    "tools:push": "git subtree push --prefix=src/_includes/11ty-starter-common git@github.com:aubreypwd/11ty-starter-common.git v2",
    "tools:pull": "git subtree pull --prefix=src/_includes/11ty-starter-common git@github.com:aubreypwd/11ty-starter-common.git v2 --squash",
    "setup": "npm run setup:git-hooks",
    "setup:git-hooks": "git config core.hooksPath .githooks",
    "postinstall": "npm run setup && ( npm run tools:pull || true )",
    "netlify:live": "netlify dev --live localhost",
    "netlify:dev": "netlify dev"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-img": "^6.0.4",
    "@aubreypwd/11ty-starter-common": "git+ssh://git@github.com:aubreypwd/11ty-starter-common.git",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@quasibit/eleventy-plugin-sitemap": "^2.2.0",
    "@sardine/eleventy-plugin-tinycss": "^2.0.0",
    "@sardine/eleventy-plugin-tinyhtml": "^0.2.0",
    "bootstrap": "^5.3.8",
    "deepmerge": "^4.3.1",
    "eleventy-google-fonts": "^0.1.0",
    "eleventy-plugin-automatic-noopener": "^2.0.2",
    "eleventy-plugin-metagen": "^1.8.3",
    "eleventy-plugin-robotstxt": "^1.0.2",
    "eleventy-sass": "^3.0.0-beta.0",
    "esbuild": "^0.27.3",
    "markdown-it": "^14.1.1",
    "module-alias": "^2.3.4",
    "node-html-parser": "^7.1.0",
    "purgecss-from-html": "^8.0.0",
    "rimraf": "^6.1.3",
    "sanitize.css": "^13.0.0",
    "schemaorg-jsd": "^0.17.1",
    "structured-data-testing-tool": "^4.5.0",
    "terser": "^5.46.0"
  }
}
