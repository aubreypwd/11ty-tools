{% for key, script in body.js.scripts | default( {} ) %}
	{% if script.src and script.inline %}
		<script type="text/javascript" {{ script.attrs | default( '' ) }}>{% readfile script.src | replace( '/assets/', 'assets/' ) %}</script>
	{% elif script.src %}
		<script type="text/javascript" src="{{ script.src }}" {{ script.attrs | default( '' ) }}></script>
	{% endif %}
{% endfor %}

{# --- 👉 main.js --- #}
{% if ( 'assets/js/main.js' | fileExists ) and ( body.js.main.enabled | default( true ) ) %}
	<script src="/assets/js/main.js" {{ body.js.main.attrs | default( '' ) }}></script>
{% endif %}

{# --- 👉 Always load bundled js in the body --- #}
<script type="text/javascript">{% getBundle 'js' %}</script>
