{% set title %}{% if title %}{{ title }}{% endif %}{% if site.title and title %} - {% endif %}{% if site.title %}{{ site.title }}{% endif %}{% endset %}

{% set meta = site.meta | deepmerge( meta ) %}
{% set metagen = site.metagen | deepmerge( metagen ) %}

{% if meta | default( {} ) | length %}

	{% metagen {
		title: metagen.title | default( title ),
		url: metagen.url | default( site.baseUrl + ( page.url | default( '' ) ) ),
		desc: metagen.desc | default( meta.description ) | default( description ),
		img: metagen.img | default( '' ),
		img_alt: metagen.img_alt | default( site.title ),
		twitter_card_type: metagen.twitter_card_type | default( 'summary_large_image' ),
		twitter_handle: metagen.twitter_handle | default( meta.twitter or '' ),
		name: metagen.name | default( meta.author or '' )
	} %}

{% else %}
	<title>{{ title }}</title>
	<meta name="viewport" content="{{ meta.viewport.content | default ( 'width=device-width, initial-scale=1' ) }}">
{% endif %}

