---js
import webpageModule from './src/_includes/11ty-starter-common/data/jsonld/webpage.js';
	const webpageJsonLD = webpageModule.default ?? webpageModule;

	import deepmergeModule from 'deepmerge';
const deepmerge = deepmergeModule.default ?? deepmergeModule;

const markdown = true;

const eleventyComputed = {
	layouts: {
		base: {
			jsonld: ( data ) => (
				{
					WebPage: webpageJsonLD(
						data.site,
						{
							'@id': `${ data.site.baseUrl }${ data.page.url }#WebPage`,
							url: `${ data.site.baseUrl }${ data.page.url }#WebPage`,
							name: data.title ?? '',
							description: data.meta?.description ?? '',
						}
					)
				}
			)
		}
	}
};
---

<!DOCTYPE html>
<html lang="{{ site.lang or 'en-US' }}">
	<head>
		{% include '11ty-starter-common/includes/layouts/partials/meta.njk' %}
		{% include '11ty-starter-common/includes/layouts/partials/google-fonts.njk' %}
		{% include '11ty-starter-common/includes/layouts/partials/ga4.njk' %}
		{% include '11ty-starter-common/includes/layouts/partials/jsonld.njk' %}

		{% include '11ty-starter-common/includes/layouts/partials/styles.njk' %}
		{% include '11ty-starter-common/includes/layouts/partials/scripts.head.njk' %}

		{# --- 👉 Appended <head> items --- #}
		{% for append in body.head.append | deepmerge( site.body.head.append ) | default( [] ) %}
			{{ append | safe }}
		{% endfor %}

		{# --- 👉 Appended <head> items via nunchucks: create this file and add your head contents there. --- #}
		{% include 'head.njk' ignore missing %}
	</head>

	<body class="{{ site.body.class }} {{ body.class }}">
		<main class="{{ site.body.main.class }} {{ body.main.class }}">
			{% if content %}
				{% if markdown != false %}
					{{ content | markdown | safe }}
				{% else %}
					{{ content | safe }}
				{% endif %}
			{% endif %}
		</main>

		{% include '11ty-starter-common/includes/layouts/partials/scripts.body.njk' %}

		{# --- 👉 Appended <body> items via nunchucks: create _includes/body.njk and add your contents there. --- #}
		{% include 'body.njk' ignore missing %}
	</body>
</html>
