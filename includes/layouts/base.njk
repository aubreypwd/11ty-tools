---
{
	markdown: true
}
---
<!DOCTYPE html>
<html lang="{{ site.lang or 'en-US' }}">
	<head>
		{% include './meta.njk' %}
		{% include './google-fonts.njk' %}
		{% include './ga4.njk' %}
		{% include './styles.njk' %}
		{% include './scripts.head.njk' %}
		{% include './jsonld.njk' %}

		{# --- 👉 Appended <head> items --- #}
		{% for append in body.head.append | default( [] ) %}
			{{ append | safe }}
		{% endfor %}
	</head>

	<body class="{{ site.body.class }} {{ body.class }}">
		<main class="{{ site.body.main.class }} {{ body.main.class }}">
			{% if content %}
				{% if markdown != false %}
					{{ content | markdown | safe }}
				{% else %}
					{{ content | safe }}
				{% endif %}
			{% endif %}
		</main>

		{% include './scripts.body.njk' %}
	</body>
</html>
