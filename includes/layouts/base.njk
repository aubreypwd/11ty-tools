---
{
	markdown: true
}
---
<!DOCTYPE html>
<html lang="{{ site.lang or 'en-US' }}">
	{%- set head = site.head | deepmerge( head ) -%}
	{%- set body = site.body | deepmerge( body ) -%}
	{%- set ga = site.ga | deepmerge( ga ) -%}

	<head>
		{% include './meta.njk' %}
		{% include './google-fonts.njk' %}
		{% include './ga4.njk' %}
		{% include './styles.njk' %}
		{% include './scripts.head.njk' %}
		{% include './jsonld.njk' %}

		{# --- 👉 Appended <head> items --- #}
		{% for append in head.append | default( [] ) %}
			{{ append | safe }}
		{% endfor %}
	</head>

	<body class="{{ body.class | default ( '' ) }}">
		<main class="{{ body.main.class | default( '' ) }}">
			{% if content %}
				{% if markdown != false %}
					{{ content | markdown | safe }}
				{% else %}
					{{ content | safe }}
				{% endif %}
			{% endif %}
		</main>

		{% include './scripts.body.njk' %}
	</body>
</html>
