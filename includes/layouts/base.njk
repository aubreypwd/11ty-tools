---
{
	markdown: true
}
---
<!DOCTYPE html>
<html lang="{{ site.lang or 'en-US' }}">
	{%- set pageBody = body | default( {} ) -%}
	{%- set body = site.body | deepmerge( pageBody ) -%}
	{% set bodyClass %}{{ site.body.class | default( '' ) }} {{ pageBody.class | default( '' ) }}{% endset %}
	{% set mainClass %}{{ site.body.main.class | default( '' ) }} {{ pageBody.main.class | default( '' ) }}{% endset %}

	<head>
		{% include './meta.njk' %}
		{% include './google-fonts.njk' %}
		{% include './ga4.njk' %}
		{% include './styles.njk' %}
		{% include './scripts.head.njk' %}
		{% include './jsonld.njk' %}

		{# --- 👉 Appended <head> items --- #}
		{% for append in body.head.append | default( [] ) %}
			{{ append | safe }}
		{% endfor %}
	</head>

	<body class="{{ bodyClass | trim }}">
		<main class="{{ mainClass | trim }}">
			{% if content %}
				{% if markdown != false %}
					{{ content | markdown | safe }}
				{% else %}
					{{ content | safe }}
				{% endif %}
			{% endif %}
		</main>

		{% include './scripts.body.njk' %}
	</body>
</html>
